{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "downlevelIteration": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "esnext",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "target": "es5",
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2018",
      "dom"
    ]
  },
  "include": ["node_modules/@angular/cdk/**/typings/index.d.ts", "src/**/*.ts"],
  "exclude": [ "**/*.spec.ts" ]
}
